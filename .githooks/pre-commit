#!/bin/sh
# pre-commit hook: enforces format, build, and test checks before every commit.
#
# Install once per clone:
#   git config core.hooksPath .githooks
# Or run: bash scripts/setup-hooks.sh / scripts/setup-hooks.ps1
set -eu

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
STAGED_CS_FILES=$(printf '%s\n' "$STAGED_FILES" | grep '\.cs$' || true)
STAGED_FRONTEND_FILES=$(printf '%s\n' "$STAGED_FILES" | grep '^frontend/' || true)

# Nothing that affects backend or frontend is staged (e.g. a docs-only commit):
# skip the heavy checks entirely.
if [ -z "$STAGED_CS_FILES" ] && [ -z "$STAGED_FRONTEND_FILES" ]; then
    exit 0
fi

# ── 1. Backend: format, build, test (only when C# files are staged) ───────────
if [ -n "$STAGED_CS_FILES" ]; then
    # --- JetBrains Cleanup Block ---
    if command -v jb > /dev/null 2>&1; then
        JB_FILES=$(printf '%s\n' "$STAGED_CS_FILES" | tr '\n' ';')

        echo "Running 'jb cleanupcode'..."

        # Run cleanup when the local JetBrains toolchain is healthy, using the same profile CI verifies
        # ("Built-in: Reformat Code") so locally-formatted files match the CI formatting check.
        # If it is installed but broken, keep build/test enforcement active.
        if jb cleanupcode "MeisterProPR.slnx" --profile="Built-in: Reformat Code" --include="$JB_FILES"; then
            # Stage ONLY the files that were in our list.
            printf '%s\n' "$STAGED_CS_FILES" | xargs git add
            echo "Cleanup complete and specific files staged."
        else
            echo "JetBrains 'jb cleanupcode' failed. Skipping cleanup and continuing with build/test checks."
        fi
    else
        echo "JetBrains 'jb' not found. Skipping cleanup."
    fi

    echo "pre-commit: format check passed."

    echo "pre-commit: running dotnet build..."
    if ! dotnet build ./MeisterProPR.slnx --no-restore --configuration Release --nologo -consoleLoggerParameters:NoSummary 2>&1; then
        echo ""
        echo "pre-commit: FAILED -- build errors detected."
        echo "Fix the compilation errors and commit again."
        exit 1
    fi

    echo "pre-commit: build passed."

    echo "pre-commit: running dotnet test..."
    if ! dotnet test ./MeisterProPR.slnx --no-build --no-restore --configuration Release --nologo --verbosity quiet 2>&1; then
        echo ""
        echo "pre-commit: FAILED -- one or more backend tests failed."
        echo "Fix the failing tests and commit again."
        exit 1
    fi

    echo "pre-commit: all backend tests passed."
fi

# ── 2. Frontend: type-check + tests (only when frontend files are staged) ─────
if [ -n "$STAGED_FRONTEND_FILES" ]; then
    echo "pre-commit: running frontend type-check..."
    if ! (cd frontend && npm run type-check); then
        echo ""
        echo "pre-commit: FAILED -- frontend type-check errors detected."
        echo "Fix the type errors and commit again."
        exit 1
    fi

    echo "pre-commit: frontend type-check passed."

    echo "pre-commit: running frontend tests..."
    if ! (cd frontend && npm run test); then
        echo ""
        echo "pre-commit: FAILED -- one or more frontend tests failed."
        echo "Fix the failing tests and commit again."
        exit 1
    fi

    echo "pre-commit: all frontend tests passed."
fi

exit 0
