#!/usr/bin/env bash
# pre-commit hook: enforces format, build, and test checks before every commit.
#
# Install once per clone:
#   git config core.hooksPath .githooks
# Or run: bash scripts/setup-hooks.sh / scripts/setup-hooks.ps1
set -euo pipefail

# Skip if no C# files are staged (avoids the overhead on docs-only commits).
if ! git diff --cached --name-only --diff-filter=ACMR | grep -q '\.cs$'; then
    exit 0
fi

# --- 1. JetBrains Cleanup Block ---
if command -v jb &> /dev/null; then

    # 1. Get the list of changed files (newline separated)
    # This format is safer for piping into other commands
    FILES_LIST=$(git diff --name-only --diff-filter=ACMR | grep '\.cs$')

    # 2. Convert to semicolon-separated for jb cleanupcode
    JB_FILES=$(echo "$FILES_LIST" | tr '\n' ';')

    if [ -n "$FILES_LIST" ]; then
        echo "Running 'jb cleanupcode'..."

        # Run cleanup
        jb cleanupcode "MeisterProPR.slnx" --include="$JB_FILES"

        # 3. Stage ONLY the files that were in our list
        # xargs passes the list of files to git add
        echo "$FILES_LIST" | xargs git add

        echo "Cleanup complete and specific files staged."
    fi
else
    echo "JetBrains 'jb' not found. Skipping cleanup."
fi

echo "pre-commit: format check passed."

# ── 2. Build ─────────────────────────────────────────────────────────────────

echo "pre-commit: running dotnet build..."

if ! dotnet build ./MeisterProPR.slnx --no-restore --configuration Release --nologo -consoleLoggerParameters:NoSummary 2>&1; then
    echo ""
    echo "pre-commit: FAILED -- build errors detected."
    echo "Fix the compilation errors and commit again."
    exit 1
fi

echo "pre-commit: build passed."

# ── 3. Test ──────────────────────────────────────────────────────────────────

echo "pre-commit: running dotnet test..."

if ! dotnet test ./MeisterProPR.slnx --no-build --no-restore --configuration Release --nologo --verbosity quiet 2>&1; then
    echo ""
    echo "pre-commit: FAILED -- one or more tests failed."
    echo "Fix the failing tests and commit again."
    exit 1
fi

echo "pre-commit: all tests passed."
