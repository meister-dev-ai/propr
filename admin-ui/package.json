{
  "name": "meister-propr-admin-ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "mock": "cross-env VITE_MOCK=true vite --mode mock",
    "generate:api": "openapi-typescript ../openapi.json -o src/services/generated/openapi.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^14.1.2",
    "chart.js": "^4.5.1",
    "dompurify": "^3.3.3",
    "markdown-it": "^14.1.1",
    "openapi-fetch": "^0.13.0",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.4.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.0.0",
    "@vue/test-utils": "^2.4.6",
    "cross-env": "^10.1.0",
    "jsdom": "^25.0.0",
    "msw": "^2.12.14",
    "openapi-typescript": "^7.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.4.2",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.1.10"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
