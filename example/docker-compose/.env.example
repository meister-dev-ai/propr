# ─── Required ───────────────────────────────────────────────────────

# JWT signing secret — must be at least 32 characters, cryptographically random
MEISTER_JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Shared ProPR <-> ProCursor key used for internal X-ProCursor-Key auth
PROCURSOR_SHARED_KEY=change-me-to-a-long-random-secret-at-least-32-chars

# Initial admin account seeded on first startup (when no admin exists in the DB)
MEISTER_BOOTSTRAP_ADMIN_USER=admin
MEISTER_BOOTSTRAP_ADMIN_PASSWORD=change-me

# ─── Optional ──────────────────────────────────────────────────────────────────

# Legacy shared admin/client key env vars have been removed.
# Configure users, PATs, client keys, and AI connections through the database-backed app flows.

# Override the default Postgres connection (defaults to docker-compose postgres service)
# DB_CONNECTION_STRING=Host=localhost;Port=5432;Database=meisterpropr;Username=postgres;Password=devpass

# Optional dedicated ProCursor operational connection string.
# Leave unset to reuse the same physical PostgreSQL database with a separate logical ownership boundary.
# PROCURSOR_DB_CONNECTION_STRING=Host=localhost;Port=5432;Database=meisterpropr;Username=postgres;Password=devpass

# Allowed CORS origins (comma-separated)
# CORS_ORIGINS=https://myproxy.example.com

# Public API base URL seen by external identity providers and webhook senders.
# For the bundled local nginx front door keep the default /api prefix.
# MEISTER_PUBLIC_BASE_URL=https://localhost:5443/api

# ProPR extracted ProCursor mode (defaults keep ProCursor enabled as a separate internal service)
# PROCURSOR_REMOTE_MODE=proprManagedRemote
# PROCURSOR_SERVICE_BASE_URL=http://procursor:8081

# ProCursor extracted host broker base URL
# PROCURSOR_PROPR_BASE_URL=http://meisterpropr:8080

# ─── Per-tier AI iteration budgets (optional — override global AI_MAX_ITERATIONS) ─
# AI_MAX_ITERATIONS_LOW=5
# AI_MAX_ITERATIONS_MEDIUM=10
# AI_MAX_ITERATIONS_HIGH=20
