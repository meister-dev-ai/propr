      }
    },
    "deployApps": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Set to false if you want to provision infrastructure without creating the app resources."
      }
    },
    "dbConnectionString": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Optional PostgreSQL connection string override stored in Key Vault. Leave empty to use the internal database app."
      }
    },
    "jwtSecret": {
      "type": "securestring",
      "metadata": {
        "description": "JWT signing secret for backend auth. Must be at least 32 characters."
      }
    },
    "bootstrapAdminUser": {
      "type": "string",
      "defaultValue": "admin",
      "metadata": {
        "description": "Bootstrap admin username seeded on first startup when no admin exists."
      }
    },
    "bootstrapAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Bootstrap admin password seeded on first startup when no admin exists."
      }
    },
    "dbUser": {
      "type": "securestring",
      "metadata": {
        "description": "PostgreSQL username stored in Key Vault."
      }
    },
    "dbPassword": {
      "type": "securestring",
      "metadata": {
        "description": "PostgreSQL password stored in Key Vault."
      }
    }
  },
  "variables": {
    "safeName": "[replace(parameters('projectName'), '-', '')]",
    "storageName": "[format('{0}sg', variables('safeName'))]",
    "kvName": "[format('kv{0}{1}', variables('safeName'), take(uniqueString(resourceGroup().id), 4))]",
    "internalDbConnectionString": "[format('Host={0}-db;Port=5432;Database=meisterpropr;Username={1};Password={2};Ssl Mode=Disable', parameters('projectName'), parameters('dbUser'), parameters('dbPassword'))]",
    "effectiveDbConnectionString": "[if(empty(parameters('dbConnectionString')), variables('internalDbConnectionString'), parameters('dbConnectionString'))]"
